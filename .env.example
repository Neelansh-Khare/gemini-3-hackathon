# Life OS - Environment Configuration
# Copy to .env and fill in values

# --- Gemini 3 ---
GEMINI_API_KEY=                    # From Google AI Studio / Vertex AI
GEMINI_MODEL=gemini-2.0-flash      # or gemini-1.5-pro for reasoning-heavy tasks

# --- LifeGraph Storage ---
LIFEGRAPH_DB_PATH=./data/lifegraph.db
VECTOR_DB_PATH=./data/vector_store

# --- MCP Connectors ---
# Gmail (OAuth - configure via Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Safety ---
REQUIRE_APPROVAL_FOR_WRITES=true   # Always require user approval before writes
